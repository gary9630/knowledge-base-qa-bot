# Copy this file outside git and replace every value before a production deploy.
KB_APP_ENV=production
KB_AUTH_SECRET_KEY=replace-with-at-least-32-random-characters
KB_PLATFORM_USERNAME=course-learner
KB_PLATFORM_PASSWORD=replace-with-strong-platform-password
KB_ADMIN_API_KEY=replace-with-strong-admin-api-key
KB_DATABASE_URL=postgresql+psycopg://kb:replace-password@postgres:5432/kb
KB_DOCS_DIR=/app/docs
KB_RAW_DIR=/app/raw
KB_KB_DIR=/app/.kb
KB_RATE_LIMIT_ENABLED=true
KB_RATE_LIMIT_WINDOW_SECONDS=60
KB_RATE_LIMIT_LOGIN_REQUESTS=10
KB_RATE_LIMIT_CHAT_REQUESTS=60
KB_RATE_LIMIT_ADMIN_REQUESTS=60
KB_RATE_LIMIT_UPLOAD_REQUESTS=10
KB_MAX_CONCURRENT_UPLOADS=2
KB_BACKGROUND_JOB_STALE_AFTER_SECONDS=3600
KB_BACKGROUND_JOB_RETRY_BASE_DELAY_SECONDS=30
KB_BACKGROUND_JOB_RETRY_MAX_DELAY_SECONDS=300
KB_WORKER_ID=production-worker-1
KB_WORKER_HEARTBEAT_INTERVAL_SECONDS=30
KB_WORKER_HEARTBEAT_STALE_AFTER_SECONDS=120
KB_PLATFORM_COHORTS=
KB_PLATFORM_EXTRA_VISIBILITY_LABELS=
KB_EMBEDDING_PROVIDER=openai
KB_ANSWER_PROVIDER=openai
KB_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
KB_OPENAI_CHAT_MODEL=gpt-5.4-mini
KB_EMBEDDING_DIMENSION=768
OPENAI_API_KEY=replace-with-openai-api-key
