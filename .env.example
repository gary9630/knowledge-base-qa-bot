KB_APP_ENV=development
KB_DATABASE_URL=postgresql+psycopg://kb:kb@postgres:5432/kb
KB_DOCS_DIR=docs
KB_RAW_DIR=raw
KB_KB_DIR=.kb
KB_DEFAULT_RETRIEVAL_STRATEGY=hybrid
KB_AUTH_SECRET_KEY=
# 學員帳號（登入後為 student 角色）
KB_PLATFORM_USERNAME=
KB_PLATFORM_PASSWORD=
# 管理者帳號（登入後為 admin 角色，可進入管理主控台）
KB_ADMIN_USERNAME=
KB_ADMIN_PASSWORD=
KB_PLATFORM_SESSION_TTL_SECONDS=86400
KB_ADMIN_API_KEY=
KB_MAX_UPLOAD_BYTES=10000000
KB_EMBEDDING_PROVIDER=fake
KB_ANSWER_PROVIDER=fake
OPENAI_API_KEY=
KB_OPENAI_EMBEDDING_MODEL=
KB_OPENAI_CHAT_MODEL=
# LLM router/guardrail 與難度分流（預設 router=gpt-5.4-mini、難題=gpt-5.4）
KB_QUERY_ROUTER_ENABLED=true
KB_OPENAI_ROUTER_MODEL=
KB_OPENAI_CHAT_MODEL_HARD=
KB_OPENAI_CHAT_MAX_COMPLETION_TOKENS=4096
KB_EMBEDDING_DIMENSION=768
